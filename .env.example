# Copy this file to .env and fill in your values

# OpenAI (required if using OpenAI models for generation)
OPENAI_API_KEY=

# Anthropic (required if using Anthropic/Claude models)
ANTHROPIC_API_KEY=

# Ollama (optional — for local model serving; no API key required)
# OLLAMA_BASE_URL=http://localhost:11434

# Default generation model (provider:name format)
# Examples: openai:gpt-5.5, anthropic:claude-opus-4-6, ollama:qwen3.6
MINERVA_MODEL=openai:gpt-5.5

# LanceDB persistence directory
LANCEDB_DIR=./lancedb
